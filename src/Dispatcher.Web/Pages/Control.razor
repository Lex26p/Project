@page "/control"
@inject ControlApiClient Api
@inject CommandRealtimeClient Realtime
@implements IAsyncDisposable

<PageTitle>Simulator control</PageTitle>

<h1>Simulator command control</h1>
<p>Commands execute only against the Simulator. Physical and protocol effects are unavailable.</p>

<section aria-label="Command target">
    <h2>Target evidence</h2>
    <input @bind="scopeText" placeholder="Runtime scope ID" />
    <input @bind="pointText" placeholder="Point ID" />
    <button type="button" @onclick="LoadContextAsync">Load live context</button>
    @if (context is not null)
    {
        <dl>
            <dt>Active revision</dt><dd>@context.RevisionId / @context.RevisionNumber / generation @context.Generation</dd>
            <dt>Current</dt><dd>@context.CurrentValue @context.Unit (@context.Quality, @context.Freshness), position @context.CurrentPosition</dd>
        </dl>
    }
</section>

<section aria-label="Control lease">
    <h2>Control lease</h2>
    <label>Lifetime, seconds <input @bind="leaseSeconds" type="number" min="1" /></label>
    <label>Step-up password <input @bind="stepUpPassword" type="password" autocomplete="current-password" /></label>
    <button type="button" @onclick="AcquireAsync">Acquire lease</button>
    @if (leaseId is not null)
    {
        <p>Lease: @leaseId</p>
        <button type="button" @onclick="RevokeAsync">Revoke lease</button>
    }
</section>

<section aria-label="Command preflight">
    <h2>Prepare intent</h2>
    <label>Desired value <input @bind="desiredValue" type="number" /></label>
    <button type="button" disabled="@(leaseId is null || context is null)" @onclick="PrepareAsync">Prepare exact intent</button>
</section>

<section aria-label="Simulator command confirmation">
    <h2>Confirm and execute</h2>
    <label><input type="checkbox" @bind="executionConfirmed" /> I confirm the exact target and desired value shown above.</label>
    <button type="button" disabled="@(intentId is null || !executionConfirmed)" @onclick="ExecuteAsync">Execute on Simulator</button>
    @if (execution is not null)
    {
        <dl>
            <dt>Execution</dt><dd>@execution.ExecutionId</dd>
            <dt>State</dt><dd>@execution.State (@execution.Progress%)</dd>
            <dt>Result</dt><dd>@(execution.ResultValue?.ToString() ?? execution.RejectionCode ?? "pending reconciliation")</dd>
        </dl>
        <button type="button" @onclick="PollRealtimeAsync">Refresh realtime state</button>
        @if (execution.State == "Unknown")
        {
            <button type="button" @onclick="ReconcileAsync">Reconcile same execution identity</button>
        }
    }
</section>

@if (!string.IsNullOrEmpty(message)) { <p role="status">@message</p> }

@code {
    private string scopeText = string.Empty, pointText = string.Empty, stepUpPassword = string.Empty;
    private int leaseSeconds = 60;
    private long desiredValue;
    private Guid? leaseId;
    private Guid? intentId;
    private CommandContextPayload? context;
    private CommandExecutionPayload? execution;
    private bool executionConfirmed;
    private bool realtimeStarted;
    private string message = string.Empty;

    private async Task LoadContextAsync()
    {
        context = Guid.TryParse(scopeText, out var scope) && Guid.TryParse(pointText, out var point)
            ? await Api.ReadContextAsync(scope, point) : null;
        message = context is null ? "Live target context is unavailable or denied." : "Live evidence loaded.";
    }

    private async Task AcquireAsync()
    {
        if (context is null) { message = "Load live context first."; return; }
        var candidate = Guid.NewGuid();
        var response = await Api.AcquireLeaseAsync(candidate, context.ScopeId, leaseSeconds, stepUpPassword);
        stepUpPassword = string.Empty;
        leaseId = response.IsSuccessStatusCode ? candidate : null;
        message = response.IsSuccessStatusCode ? "Control lease acquired." : $"Lease rejected ({(int)response.StatusCode}).";
    }

    private async Task PrepareAsync()
    {
        if (context is null || leaseId is null) return;
        var candidate = Guid.NewGuid();
        var response = await Api.PrepareAsync(candidate, leaseId.Value, context, desiredValue);
        intentId = response.IsSuccessStatusCode ? candidate : null;
        execution = null;
        executionConfirmed = false;
        message = response.IsSuccessStatusCode
            ? "Intent prepared. Confirm the exact Simulator command before execution."
            : $"Preflight rejected ({(int)response.StatusCode}). Reload live evidence before retrying.";
    }

    private async Task ExecuteAsync()
    {
        if (context is null || intentId is null || !executionConfirmed) return;
        var candidate = Guid.NewGuid();
        var response = await Api.ExecuteAsync(candidate, intentId.Value, context.ScopeId, context.PointId);
        execution = await ControlApiClient.ReadExecutionAsync(response);
        executionConfirmed = false;
        message = execution is null
            ? $"Execution rejected ({(int)response.StatusCode})."
            : execution.State == "Unknown"
                ? "Outcome is unknown. Reconcile the same execution identity; do not issue a new command."
                : $"Simulator execution is {execution.State}.";
        if (execution is not null)
        {
            try
            {
                var snapshot = await Realtime.StartAsync(context.ScopeId);
                realtimeStarted = true;
                execution = snapshot.Executions.SingleOrDefault(value => value.ExecutionId == candidate) ?? execution;
            }
            catch (Exception) { realtimeStarted = false; }
        }
    }

    private async Task PollRealtimeAsync()
    {
        if (execution is null || context is null) return;
        try
        {
            if (!realtimeStarted)
            {
                var snapshot = await Realtime.StartAsync(context.ScopeId);
                realtimeStarted = true;
                execution = snapshot.Executions.SingleOrDefault(value => value.ExecutionId == execution.ExecutionId) ?? execution;
                return;
            }
            var feed = await Realtime.PollAsync();
            var latest = feed.Transitions.LastOrDefault(value => value.ExecutionId == execution.ExecutionId);
            if (latest is not null)
                execution = execution with
                {
                    State = latest.State, Progress = latest.Progress, ResultValue = latest.ResultValue,
                    RejectionCode = latest.RejectionCode, UpdatedAt = latest.OccurredAt, Version = latest.Version,
                };
        }
        catch (Exception) { realtimeStarted = false; message = "Realtime unavailable; use reconciliation for unknown outcome."; }
    }

    private async Task ReconcileAsync()
    {
        if (execution is null || context is null) return;
        var response = await Api.ReconcileAsync(execution.ExecutionId, context.ScopeId, context.PointId);
        execution = await ControlApiClient.ReadExecutionAsync(response) ?? execution;
        message = execution.State == "Unknown"
            ? "No durable Simulator result is available yet; outcome remains unknown."
            : $"Reconciled previous Simulator result: {execution.State}.";
    }

    private async Task RevokeAsync()
    {
        if (leaseId is null) return;
        await Api.RevokeLeaseAsync(leaseId.Value);
        leaseId = null;
        intentId = null;
        execution = null;
        message = "Control lease revoked.";
    }

    public async ValueTask DisposeAsync() => await Realtime.DisposeAsync();
}

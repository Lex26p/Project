@page "/equipment"
@inject RegistryApiClient Api
@inject NavigationManager Navigation

<PageTitle>Equipment</PageTitle>

<GuardedContent Route="/equipment">
    <h1>Equipment</h1>
    @if (scopes is null)
    {
        <p>Loading equipment…</p>
    }
    else if (scopes.Count == 0)
    {
        <p>No accessible equipment scope.</p>
    }
    else
    {
        <label>
            Scope
            <select value="@selectedScope" @onchange="SelectScopeAsync">
                @foreach (var scope in scopes)
                {
                    <option value="@scope.ScopeId">@scope.Label (@scope.EquipmentCount)</option>
                }
            </select>
        </label>
        <label>Filter <input @bind="query" /></label>
        <button type="button" @onclick="LoadAsync">Search</button>
        @if (equipment is not null)
        {
            <p>@equipment.Total equipment item(s)</p>
            <ul>
                @foreach (var item in equipment.Items)
                {
                    <li><a href="@($"/equipment/{item.EquipmentId:D}?scope={selectedScope:D}")">@item.Code — @item.Name</a> (@item.PointCount point(s))</li>
                }
            </ul>
        }
    }
</GuardedContent>

@code {
    private IReadOnlyList<RegistryScopePayload>? scopes;
    private EquipmentListPayload? equipment;
    private Guid selectedScope;
    private string query = string.Empty;

    [SupplyParameterFromQuery(Name = "scope")]
    public Guid? RequestedScope { get; set; }

    protected override async Task OnInitializedAsync()
    {
        scopes = await Api.ReadScopesAsync() ?? [];
        selectedScope = scopes.Any(scope => scope.ScopeId == RequestedScope)
            ? RequestedScope!.Value
            : scopes.FirstOrDefault()?.ScopeId ?? Guid.Empty;
        await LoadAsync();
    }

    private async Task SelectScopeAsync(ChangeEventArgs args)
    {
        if (Guid.TryParse(args.Value?.ToString(), out var value))
        {
            selectedScope = value;
            Navigation.NavigateTo($"/equipment?scope={selectedScope:D}", false, true);
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        if (selectedScope != Guid.Empty)
        {
            equipment = await Api.ReadEquipmentAsync(selectedScope, query);
        }
    }
}
